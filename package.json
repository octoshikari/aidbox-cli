{
  "name": "@octoshikari/aidbox-types-generator",
  "version": "1.0.0",
  "description": "Types generator for Aidbox resources",
  "scripts": {
    "command:help": "npm exec -- ts-node --transpile-only bin/aidbox-types-generator --help",
    "command:clear-cache": "npm exec -- ts-node --transpile-only bin/aidbox-types-generator clear-cache",
    "command:generate": "npm exec -- ts-node --transpile-only bin/aidbox-types-generator generate",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "test": "uvu -r tsm tests",
    "test:watch": "watchlist lib tests -- npm test"
  },
  "bin": {
    "aidbox-types-generator": "./bin/aidbox-types-generator.js"
  },
  "keywords": [
    "fhir",
    "aidbox"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^0.26.1",
    "cli-progress": "^3.10.0",
    "debug": "^4.3.4",
    "prettier": "2.6.2",
    "yargs": "^17.4.1"
  },
  "bugs": {
    "url": "https://github.com/Aidbox/types-generator/issues"
  },
  "homepage": "https://github.com/Aidbox/types-generator#readme",
  "devDependencies": {
    "@types/cli-progress": "^3.9.2",
    "@types/debug": "^4.1.7",
    "@types/node": "16.11.29",
    "@types/prettier": "^2.6.0",
    "@types/yargs": "^17.0.10",
    "@typescript-eslint/eslint-plugin": "^5.21.0",
    "@typescript-eslint/parser": "^5.21.0",
    "axios-mock-adapter": "^1.20.0",
    "eslint": "^8.14.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.0.0",
    "fast-check": "^2.24.0",
    "nodemon": "2.0.15",
    "ts-node": "^10.7.0",
    "tsm": "^2.2.1",
    "typescript": "^4.6.3",
    "uvu": "0.5.3",
    "watchlist": "0.3.1"
  }
}
