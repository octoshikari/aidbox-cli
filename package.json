{
  "name": "@octoshikari-oss/aidbox-types-generator",
  "version": "1.0.0",
  "description": "Types generator for Aidbox resources",
  "scripts": {
    "command:help": "npm exec -- ts-node --transpile-only bin/aidbox-types-generator --help",
    "command:clear-cache": "npm exec -- ts-node --transpile-only bin/aidbox-types-generator clear-cache",
    "command:generate": "npm exec -- ts-node --transpile-only bin/aidbox-types-generator generate",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "test": "uvu -r tsm tests",
    "build": "tsc",
    "test:watch": "watchlist lib tests -- npm test",
    "package:linux": "pkg . --no-bytecode --targets node14-linux-x64 --out-path binary/linux",
    "package:macos": "pkg .  --no-bytecode --targets node14-macos-x64,node14-macos-arm64 --out-path binary/macos",
    "package:win": "pkg .  --no-bytecode --targets node14-win-x64 --out-path binary/win"
  },
  "bin": {
    "aidbox-types-generator": "./build/bin/aidbox-types-generator.js"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "/build"
  ],
  "pkg": {
    "scripts": "build/**/*.js"
  },
  "keywords": [
    "fhir",
    "aidbox"
  ],
  "author": "Alex Streltsov <funyloony@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/octoshikari/aidbox-types-generator#readme",
  "bugs": "https://github.com/octoshikari/aidbox-types-generatorissues",
  "dependencies": {
    "axios": "^0.26.1",
    "cli-progress": "^3.10.0",
    "debug": "^4.3.4",
    "prettier": "2.6.2",
    "yargs": "^17.4.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.9.2",
    "@types/debug": "^4.1.7",
    "@types/node": "16.11.29",
    "@types/prettier": "^2.6.0",
    "@types/yargs": "^17.0.10",
    "@typescript-eslint/eslint-plugin": "^5.21.0",
    "@typescript-eslint/parser": "^5.21.0",
    "axios-mock-adapter": "^1.20.0",
    "eslint": "^8.14.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.0.0",
    "fast-check": "^2.24.0",
    "nodemon": "2.0.15",
    "pkg": "^5.6.0",
    "ts-node": "^10.7.0",
    "tsm": "^2.2.1",
    "typescript": "^4.6.3",
    "uvu": "0.5.3",
    "watchlist": "0.3.1"
  }
}
